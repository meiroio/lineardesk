# Local dev uses the docker compose Postgres (compose.yml).
# Production (Vercel + Neon): use the Neon POOLED connection string, e.g.
#   postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/lineardesk?sslmode=require
# Run migrations against the Neon DIRECT (non-pooled) URL.
DATABASE_URL=postgres://lineardesk:lineardesk@localhost:5433/lineardesk
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
# Production: your deployed origin, e.g. https://lineardesk.vercel.app
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAINS=example.com
LINEAR_API_KEY=
LINEAR_TEAM_ID=87e7afa0-8d4c-4c43-86a5-090799f403b9
LINEAR_TEAM_KEY=BAS
LINEAR_INITIAL_STATE_NAME=Triage
LINEAR_LABEL_NAME=Bug
LINEAR_WEBHOOK_SECRET=
